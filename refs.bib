@article{3dprinting_review,
title = {Additive manufacturing (3D printing): A review of materials, methods, applications and challenges},
journal = {Materials Today: Proceedings},
year = {2023},
issn = {2214-7853},
doi = {https://doi.org/10.1016/j.matpr.2023.11.033},
url = {https://www.sciencedirect.com/science/article/pii/S2214785323051027},
author = {Vilas J Kharat and Puran Singh and G {Sharath Raju} and Dinesh {Kumar Yadav} and M Satyanarayana.Gupta and Vanya Arun and Ali {Hussein Majeed} and Navdeep Singh},
keywords = {Additive manufacturing, 3D printing, Buildings, Aerospace Biomaterials, Protective structures},
abstract = {Several benefits can be gained by using additive Manufacturing (AM) or 3D printing, including design flexibility, mass customization, waste minimization, quickly producing complex structures, and rapid prototyping. The standard methods and materials used in 3D printing, along with their development and use, have been examined. The various applications of AM were discussed, especially in biology, aircraft, building, and defensive structures. Many materials and their stages of evolution, including concrete, ceramics, polymer composites, and metal alloys, were analyzed. We discussed several fundamental processing challenges that arise, including but not limited to void generation, anisotropic behaviors, computer design restrictions, and a layered appearance. This article thoroughly assesses 3D printing, including a survey of its pros and shortcomings, to establish a baseline for future research and development.}
}

